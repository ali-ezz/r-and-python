{
  "title": "SMS — Student Management System",
  "uid": "sms-overview",
  "version": 1,
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate (req/s)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(sms_http_requests_total[1m])", "legendFormat": "req/s" }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate (5xx)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "rate(sms_http_requests_total{status_code=~'5..'}[5m])", "legendFormat": "errors/s" }],
      "options": { "colorMode": "background", "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 0.1}] } }
    },
    {
      "id": 3, "type": "stat", "title": "Cache Hit Ratio",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(sms_cache_hits_total[5m]) / (rate(sms_cache_hits_total[5m]) + rate(sms_cache_misses_total[5m]))", "legendFormat": "hit ratio" }],
      "options": { "unit": "percentunit", "colorMode": "background" }
    },
    {
      "id": 4, "type": "stat", "title": "Active Students",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "sms_active_students", "legendFormat": "students" }],
      "options": { "colorMode": "background" }
    },
    {
      "id": 5, "type": "graph", "title": "HTTP Latency (p50, p95, p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(sms_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(sms_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(sms_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "yAxes": [{ "unit": "s", "label": "Latency" }]
    },
    {
      "id": 6, "type": "graph", "title": "Requests by Status Code",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "sum by (status_code) (rate(sms_http_requests_total[5m]))", "legendFormat": "{{status_code}}" }
      ]
    },
    {
      "id": 7, "type": "graph", "title": "Search Query Volume",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(sms_search_queries_total[5m])", "legendFormat": "{{has_results}}" }
      ]
    },
    {
      "id": 8, "type": "graph", "title": "Node.js Memory Usage",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "sms_nodejs_heap_used_bytes", "legendFormat": "heap used" },
        { "expr": "sms_nodejs_heap_size_total_bytes", "legendFormat": "heap total" }
      ],
      "yAxes": [{ "unit": "bytes" }]
    }
  ]
}
